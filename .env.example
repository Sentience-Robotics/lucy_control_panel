# Dev server port (default 5000). Use http://localhost:5000 if VITE_HTTPS is false.
VITE_PORT=5000
VITE_OVERRIDE_ROS_BRIDGE_SERVER_URL=

# Set false for local dev without SSL (avoids ERR_SSL_PROTOCOL_ERROR). Set true and add certs for HTTPS.
VITE_HTTPS=false
VITE_SSL_CERT_PATH=./certs/cert.pem
VITE_SSL_KEY_PATH=./certs/key.pem

# password as MD5 hash
VITE_LOCAL_PASSWORD=
VITE_LOCAL_USERNAME=

VITE_ENABLE_LOGS=

#----#

# Link used in the "Documentation" button. Should point to the online documentation.
VITE_DOCUMENTATION_URL=
