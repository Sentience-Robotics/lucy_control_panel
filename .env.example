# Dev server port (default 5000). Use http://localhost:5000 if VITE_HTTPS is false.
VITE_PORT=5000
VITE_OVERRIDE_ROS_BRIDGE_SERVER_URL=

# Set false for local dev without SSL (avoids ERR_SSL_PROTOCOL_ERROR). Set true and add certs for HTTPS.
VITE_HTTPS=false
VITE_SSL_CERT_PATH=./certs/cert.pem
VITE_SSL_KEY_PATH=./certs/key.pem

# password as MD5 hash
VITE_LOCAL_PASSWORD=
VITE_LOCAL_USERNAME=

VITE_ENABLE_LOGS=

# Absolute paths to the robot model files on this machine.
# The dev server serves /robot.urdf and /meshes/* directly from these paths.
#
# Plain URDF example:
#   ROBOT_URDF_PATH=/path/to/robot.urdf
#   ROBOT_MESHES_PATH=/path/to/meshes          ← parent dir that contains stl/, dae/, etc.
#
# Xacro example (robot_description.urdf.xacro):
#   ROBOT_URDF_PATH=/path/to/robot_description/urdf/robot_description.urdf.xacro
#   ROBOT_MESHES_PATH=/path/to/robot_description/meshes   ← parent dir (NOT the dae/ subfolder)
#
# When ROBOT_URDF_PATH ends in .xacro the dev server expands it automatically:
#   ${mesh_dir}  →  file://ROBOT_MESHES_PATH/dae  (or ROBOT_MESHES_PATH if no dae/ subdir)
#   ${use_gazebo_sim}  →  false
#
# After changing these values, restart the dev server (Ctrl-C → yarn dev).
ROBOT_URDF_PATH=/path/to/robot.urdf
ROBOT_MESHES_PATH=/path/to/meshes

# Group rotation applied to the whole robot in the 3D viewer (Euler XYZ, radians).
# STL URDFs (Z-up vertices, full FK):         VITE_ROBOT_GROUP_ROTATION=-1.5708,0,0
# DAE/xacro URDFs (global Y-up vertices):     VITE_ROBOT_GROUP_ROTATION=0,0,0
VITE_ROBOT_GROUP_ROTATION=0,0,0
